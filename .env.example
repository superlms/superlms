APP_NAME=SuperLMS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8080

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=superlms
DB_USERNAME=superlms
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log

# Default disk for file uploads. The codebase wraps S3 calls in
# App\Helpers\FileUploadHelper. Set to "s3" once AWS_* below are filled in.
# See S3_SETUP.md for the full provisioning runbook.
FILESYSTEM_DISK=s3

QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# S3 — file storage for user uploads (homework, exam copies, photos, etc.)
# IAM user should have only s3:PutObject / s3:PutObjectAcl / s3:GetObject /
# s3:DeleteObject / s3:ListBucket scoped to this bucket. See S3_SETUP.md.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
# Optional but recommended — without it, Storage::url() may build broken paths.
# Format: https://<BUCKET>.s3.<REGION>.amazonaws.com
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FIREBASE_CREDENTIALS=

# ─── ZeptoMail (Zoho transactional email) ──────────────────────────────────
# Get API token from: https://zeptomail.zoho.in → Settings → API Tokens
ZEPTOMAIL_API_URL=https://api.zeptomail.in/v1.1
ZEPTOMAIL_API_TOKEN=
ZEPTOMAIL_FROM_EMAIL=noreply@superlms.in
ZEPTOMAIL_FROM_NAME="SuperLMS"
ZEPTOMAIL_BOUNCE_ADDRESS=

# Template keys — copy from ZeptoMail dashboard → Templates → (template) → API Info
# Merge fields required per template:
#   OTP:              OTP, name, organization_name, team, product_name
#   Student password: password, school_name, admission_number, username
#   Teacher password: password, email_address, school_name, username
ZEPTOMAIL_OTP_TEMPLATE_KEY=
ZEPTOMAIL_STUDENT_PASSWORD_TEMPLATE_KEY=
ZEPTOMAIL_TEACHER_PASSWORD_TEMPLATE_KEY=
ZEPTOMAIL_WELCOME_TEMPLATE_KEY=
ZEPTOMAIL_FEE_RECEIPT_TEMPLATE_KEY=
ZEPTOMAIL_ANNOUNCEMENT_TEMPLATE_KEY=
ZEPTOMAIL_PASSWORD_CHANGED_TEMPLATE_KEY=
ZEPTOMAIL_SCHOOL_CREATION_TEMPLATE_KEY=

# ── PhonePe Standard Checkout (online fee payment) ──────────────────────────
# From PhonePe Business → Developer Settings → API Keys.
# PHONEPE_ENV: "sandbox" for Test Mode, "production" when live.
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=sandbox
# Webhook auth — set the SAME username/password under Developer Settings → Webhooks.
PHONEPE_WEBHOOK_USERNAME=
PHONEPE_WEBHOOK_PASSWORD=
